# Flirexa — Environment Configuration
# Copy this file to .env and adjust values
# Secrets are auto-generated during installation

# ============================================================================
# DATABASE
# ============================================================================
DATABASE_URL=postgresql://vpnmanager:CHANGE_ME@localhost:5432/vpnmanager_db

# ============================================================================
# API SERVER
# ============================================================================
API_HOST=0.0.0.0
API_PORT=10086

# ============================================================================
# SECURITY
# ============================================================================
# JWT secret for admin panel (auto-generated during install)
SECRET_KEY=change-this-to-a-random-secret-key

# Field-level encryption key for WireGuard private keys and other sensitive DB columns.
# Generated automatically during install. BACK THIS UP — if you restore to a different
# server without this key, all WireGuard private keys will be unreadable.
# To regenerate manually: openssl rand -hex 32
VMS_ENCRYPTION_KEY=

# ============================================================================
# TELEGRAM BOTS (optional)
# Configure via web panel (Settings → Bots) or edit values below
# ============================================================================
ADMIN_BOT_TOKEN=
ADMIN_BOT_ALLOWED_USERS=
CLIENT_BOT_TOKEN=
CLIENT_BOT_ENABLED=false

# Auto-generated email domain for Telegram bot users
AUTO_EMAIL_DOMAIN=vpnmanager.local
# Client Portal URL (shown in bot messages after payment)
CLIENT_PORTAL_URL=http://your-server:10090
ADMIN_PANEL_URL=http://your-server:10086

# Web access / reverse proxy (optional)
WEB_SETUP_MODE=none
CLIENT_PORTAL_DOMAIN=
ADMIN_PANEL_DOMAIN=
ADMIN_ACCESS_MODE=raw_ports
CERTBOT_EMAIL=

# ============================================================================
# WIREGUARD
# ============================================================================
WG_INTERFACE=wg0
WG_CONFIG_PATH=/etc/wireguard/wg0.conf
SERVER_ENDPOINT=YOUR_SERVER_IP:51820
DNS_SERVERS=1.1.1.1,1.0.0.1

# ============================================================================
# MODULES
# ============================================================================
PAYMENT_ENABLED=false
LICENSE_CHECK_ENABLED=true
LICENSE_KEY=

# Instance ID — auto-generated on first start; DO NOT edit manually
INSTANCE_ID=

# Trial tracking — auto-set on first run; DO NOT edit manually
# Changing these values will not extend the trial — hardware binding prevents abuse
TRIAL_STARTED_AT=
TRIAL_HARDWARE_ID=

# ── Centralized License Server ─────────────────────────────────────────────────
# License server URLs are embedded in the package (data/license_servers.signed)
# and cannot be configured here — this ensures integrity.
# To update servers, use the migration code from your vendor via Admin → Settings.

# How often to contact the license server (seconds). Default: 14400 (4 hours).
LICENSE_CHECK_INTERVAL=14400

# Retry interval after a failed contact (seconds). Default: 900 (15 min).
LICENSE_CHECK_RETRY=900

# Grace period before blocking when server is unreachable (hours). Default: 72.
LICENSE_GRACE_PERIOD_HOURS=72

# Path to the server_verify_public.pem (default: project root).
# Only change this if you moved the file.
# SERVER_VERIFY_PUBLIC_KEY_PATH=

# ============================================================================
# BACKGROUND WORKER
# ============================================================================
# Set to true to run background tasks (traffic sync, subscription expiry,
# backup scheduling) in a separate worker process instead of inside the API.
# Recommended for production. Requires starting spongebot-worker.service.
WORKER_ENABLED=true

# Leave API background tasks enabled by default.
# Set to false only if you intentionally run a separate scheduler process.
SCHEDULER_IN_API=true

# Safety fuse for src.api.scheduler_runner.
# Do NOT enable together with WORKER_ENABLED=true.
SCHEDULER_STANDALONE_ENABLED=false

# ============================================================================
# REMOTE AGENT (for multi-server setups)
# ============================================================================
# API key for authenticating remote agents. Auto-generated during install.
# Must match the key configured on each child server's agent.
AGENT_API_KEY=

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=INFO
SQL_ECHO=false

# ============================================================================
# CLIENT PORTAL & PAYMENTS
# ============================================================================

# CryptoPay (Telegram @CryptoBot)
CRYPTOPAY_API_TOKEN=
CRYPTOPAY_TESTNET=false

# PayPal (https://developer.paypal.com/dashboard/applications)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_SANDBOX=true

# NOWPayments (https://nowpayments.io/)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=false

# JWT Secret for client authentication (auto-generated during install)
JWT_SECRET=change-this-to-a-random-secret-key-for-jwt
JWT_EXPIRATION_HOURS=24

# Client Portal Server (separate from admin panel)
CLIENT_PORTAL_HOST=0.0.0.0
CLIENT_PORTAL_PORT=10090

# Internal communication between Client Portal and Admin API
# Auto-generated during install — must match on both services
SERVICE_API_TOKEN=change-this-to-a-random-service-token
ADMIN_API_URL=http://localhost:10086

# CORS (comma-separated origins, leave empty for default)
CORS_ORIGINS=

# ============================================================================
# SMTP EMAIL (optional)
# ============================================================================
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_TLS=true
SMTP_FROM=
